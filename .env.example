DJANGO_SECRET_KEY=change-me-backend-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=domain_admin
POSTGRES_USER=domain_admin
POSTGRES_PASSWORD=domain_admin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
DOMAIN_AGENT_TIMEOUT=20
DOMAIN_AGENT_DEFAULT_SECRET=change-me-agent-secret
# URL веб-интерфейса для других хостов (curl скачивает агент через Next → /api/backend/...).
PANEL_PUBLIC_BASE_URL=http://localhost:3000
# Отдельный токен скачивания архива агента; если пусто — используется DOMAIN_AGENT_DEFAULT_SECRET.
# AGENT_DOWNLOAD_TOKEN=

# Первый администратор панели (только если БД пустая, см. ensure_panel_admin).
PANEL_BOOTSTRAP_USERNAME=admin
PANEL_BOOTSTRAP_PASSWORD=change-me-panel-admin
PANEL_BOOTSTRAP_EMAIL=

# Скрипты с панели (тот же token, что у архива агента):
#   GET /api/backend/agent/join-workstation.sh/?token=...
#   GET /api/backend/agent/provision-dc.sh/?token=...

# Ручной сброс доменных данных в БД (серверы, задачи, шаблоны, по умолчанию аудит), без удаления User:
#   docker compose exec backend python manage.py purge_panel_data
# Полный сброс Postgres: docker compose down -v
# Опции команды: --keep-audit, --purge-sessions, --purge-jwt-blacklist
# Автоочистка при каждом старте backend (осторожно в проде):
#   PANEL_PURGE_DOMAIN_ON_STARTUP=1

AGENT_SHARED_SECRET=change-me-agent-secret
AGENT_DNS_SERVER=127.0.0.1
AGENT_DNS_ADMIN_USER=Administrator
AGENT_DNS_ADMIN_PASSWORD=change-me-domain-password
AGENT_DEFAULT_DOMAIN_DNS=test.alt
AGENT_DEFAULT_REALM=TEST.ALT
AGENT_PRIMARY_DC_IP=192.168.77.10

NEXT_PUBLIC_API_URL=http://localhost:8000/api
